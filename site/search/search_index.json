002)</p>"},{"location":"interest/#_4","title":"\ud83d\udca1 \u4ee5\u540e\u5199\u7b14\u8bb0\u7684\u6b63\u786e\u5fc3\u6001","text":"<p>\u4ee5\u540e\u4f60\u4f1a\u7ecf\u5e38\u5728 Typora \u91cc\u5199\u7b14\u8bb0\u3002\u8bf7\u8bb0\u4f4f\u8fd9\u4e2a\u201c\u9ec4\u91d1\u6cd5\u5219\u201d\uff1a</p> <p>\u628a Typora \u5f53\u6210\u4f60\u7684\u201c\u8349\u7a3f\u672c\u201d\uff0c\u628a\u672c\u5730\u7f51\u7ad9\uff08localhost:8000\uff09\u5f53\u6210\u4f60\u7684\u201c\u6700\u7ec8\u5370\u5237\u7248\u201d\u3002</p> <ol> <li>\u50cf\u6587\u5b57\u3001\u52a0\u7c97\u3001\u56fe\u7247\u3001\u666e\u901a\u516c\u5f0f\u3001\u4ee3\u7801\u5757\uff0c\u8fd9\u4e9b\u5728 Typora \u548c\u7f51\u7ad9\u91cc\u770b\u8d77\u6765\u662f\u4e00\u6a21\u4e00\u6837\u7684\u3002</li> <li>\u5f53\u4f60\u7528\u5230\u7f51\u7ad9\u4e13\u6709\u7684\u9ad8\u7ea7\u7279\u6548\uff08\u6bd4\u5982 <code>!!! note</code> \u63d0\u793a\u6846\u3001\u6392\u7248\u6807\u7b7e\u9875\u7b49\uff09\u65f6\uff0c\u4e0d\u8981\u7ba1 Typora \u91cc\u5b83\u957f\u5f97\u591a\u4e11\uff0c\u53ea\u8981\u4f60\u5728\u53f3\u8fb9\u7684\u7f51\u9875\u6d4f\u89c8\u5668\u91cc\u770b\u5230\u5b83\u662f\u6f02\u4eae\u7684\u5c31\u884c\u4e86\uff01</li> </ol> <p>\u53bb\u6539\u4e00\u4e0b <code>yml</code> \u5e76\u8c03\u6574\u4e00\u4e0b\u4ee3\u7801\u5757\u683c\u5f0f\uff0c\u770b\u770b\u7f51\u9875\u662f\u4e0d\u662f\u77ac\u95f4\u5b8c\u7f8e\u4e86\uff1f</p>"},{"location":"math/","title":"\u751f\u547d\u4e3a\u4f60\u4eec\u800c\u706b","text":""},{"location":"math/#virtreal","title":"\u6b22\u8fce\u6765\u5230VirtReal\u7684\u7b14\u8bb0\u672c","text":"<p>\u8fd9\u662f\u4e00\u4e2a\u7535\u5b50\u7b14\u8bb0\u672c\uff0c\u4e3b\u8981\u7528\u4e8e\u8bb0\u5f55\u4e00\u4e9b\u5173\u4e8e\u6211\u4e2a\u4eba\u5927\u5b66\u5b66\u4e60\u4e0e\u751f\u6d3b\u7684\u65e5\u5e38\u70b9\u6ef4\uff0c\u76ee\u524d\u6b63\u5728\u8d77\u6b65\u9636\u6bb5\uff0c\u671b\u5404\u4f4d\u6b63\u5728\u9605\u8bfb\u7b14\u8bb0\u7684\u670b\u53cb\u4eec\u591a\u591a\u5305\u6db5\uff0c\u4e5f\u975e\u5e38\u6b22\u8fce\u5927\u5bb6\u6279\u8bc4\u6307\u6b63\uff0