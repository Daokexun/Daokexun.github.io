ication","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/comm/wireless/","title":"wireless","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/embedded/c-embedded/","title":"c embedded","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/embedded/fpga/","title":"fpga","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/embedded/hw-sw-co-design/","title":"hw sw co design","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/embedded/mcu/","title":"mcu","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/foundation/calculus/","title":"calculus","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/foundation/linear-algebra/","title":"linear algebra","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/foundation/physics/","title":"physics","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/foundation/probability/","title":"probability","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/lab/course-labs/","title":"course labs","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/lab/graduation-project/","title":"graduation project","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/lab/open-source-projects/","title":"open source projects","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/signals/dsp/","title":"dsp","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/signals/information-theory/","title":"information theory","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ee/signals/signals-and-systems/","title":"signals and systems","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/","title":"qkd","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/engineering/lab-notes/","title":"lab notes","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/engineering/optics/","title":"optics","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/engineering/system/","title":"system","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/foundation/qi/","title":"QKD \u91cf\u5b50\u4fe1\u606f\u57fa\u7840","text":""},{"location":"qkd/foundation/qi/#_1","title":"\u5f15\u8a00 \ud83d\ude80","text":"<p>\u91cf\u5b50\u5bc6\u94a5\u5206\u53d1\uff08QKD\uff09\u7684\u6838\u5fc3\u76ee\u6807\u662f\uff1a\u5728\u53ef\u9a8c\u8bc1\u5b89\u5168\u6027\u7684\u524d\u63d0\u4e0b\uff0c\u8ba9\u901a\u4fe1\u53cc\u65b9\u751f\u6210\u5171\u4eab\u968f\u673a\u5bc6\u94a5\u3002 \u672c\u9875\u805a\u7126 QKD \u6240\u9700\u7684\u91cf\u5b50\u4fe1\u606f\u5b66\u57fa\u7840\u6982\u5ff5\uff0c\u5f3a\u8c03\u201c\u80fd\u7528\u4e8e\u5de5\u7a0b\u5224\u65ad\u201d\u7684\u77e5\u8bc6\u6846\u67b6\uff0c\u800c\u4e0d\u4ec5\u662f\u516c\u5f0f\u8bb0\u5fc6\u3002</p> <p>\u6838\u5fc3\u6982\u5ff5</p> <ul> <li>\u91cf\u5b50\u6bd4\u7279\uff08Qubit\uff09\uff1a\u4e8c\u7ef4\u590d\u5e0c\u5c14\u4f2f\u7279\u7a7a\u95f4\u4e2d\u7684\u6001\u5411\u91cf\uff0c\u53ef\u5904\u4e8e\u53e0\u52a0\u6001\u3002</li> <li>\u6d4b\u91cf\u6270\u52a8\uff1a\u5bf9\u672a\u77e5\u91cf\u5b50\u6001\u7684\u6d4b\u91cf\u4f1a\u5f15\u5165\u4e0d\u53ef\u5ffd\u7565\u7684\u72b6\u6001\u584c\u7f29\uff0c\u662f QKD \u5b89\u5168\u6027\u7684\u7269\u7406\u6839\u57fa\u4e4b\u4e00\u3002</li> <li>\u4e0d\u53ef\u514b\u9686\u5b9a\u7406\uff1a\u672a\u77e5\u91cf\u5b50\u6001\u65e0\u6cd5\u88ab\u5b8c\u7f8e\u590d\u5236\uff0c\u9650\u5236\u4e86\u7a83\u542c\u8005\u7684\u65e0\u635f\u590d\u5236\u653b\u51fb\u3002</li> <li>\u57fa\u9009\u62e9\u4e0e\u8bef\u7801\u7387\uff08QBER\uff09\uff1a\u534f\u8bae\u4e2d\u968f\u673a\u57fa\u9009\u62e9\u53ef\u66b4\u9732\u7a83\u542c\u884c\u4e3a\uff0cQBER \u662f\u5b89\u5168\u8bc4\u4f30\u5173\u952e\u6307\u6807\u3002</li> </ul> <p>\u907f\u5751\u6307\u5357</p> <ul> <li>\u4e0d\u8981\u628a\u201c\u91cf\u5b50\u968f\u673a\u201d\u4e0e\u201c\u7cfb\u7edf\u7edd\u5bf9\u5b89\u5168\u201d\u753b\u7b49\u53f7\uff0c\u5b9e\u9645\u7cfb\u7edf\u4ecd\u53d7\u5668\u4ef6\u7f3a\u9677\u4e0e\u4fa7\u4fe1\u9053\u5f71\u54cd\u3002</li> <li>\u4e0d\u8981\u5ffd\u7565\u6709\u9650\u7801\u957f\u6548\u5e94\uff0c\u5b9e\u9a8c\u5ba4\u63a8\u5bfc\u7684\u6e10\u8fd1\u7ed3\u679c\u4e0d\u80fd\u76f4\u63a5\u5957\u7528\u5230\u77ed\u5e27\u573a\u666f\u3002</li> <li>\u4e0d\u8981\u53ea\u770b\u5e73\u5747\u8bef\u7801\u7387\uff0c\u65f6\u5e8f\u6f02\u79fb\u548c\u504f\u7f6e\u8bef\u5dee\u4e5f\u4f1a\u663e\u8457\u5f71\u54cd\u5bc6\u94a5\u7387\u4e0e\u5b89\u5168\u8fb9\u754c\u3002</li> <li>\u4e0d\u8981\u628a\u4eff\u771f\u53c2\u6570\u5199\u6b7b\uff0c\u5efa\u8bae\u4fdd\u7559\u53ef\u914d\u7f6e\u53c2\u6570\u5e76\u8bb0\u5f55\u6bcf\u6b21\u5b9e\u9a8c\u914d\u7f6e\u3002</li> </ul>"},{"location":"qkd/foundation/qi/#_2","title":"\u6700\u5c0f\u77e5\u8bc6\u9aa8\u67b6","text":"<ol> <li>\u91cf\u5b50\u6001\u8868\u793a\uff1a\u7eaf\u6001\u3001\u6df7\u6001\u3001\u5bc6\u5ea6\u77e9\u9635\u3002</li> <li>\u91cf\u5b50\u6d4b\u91cf\uff1a\u6295\u5f71\u6d4b\u91cf\u3001POVM\u3001\u6d4b\u91cf\u540e\u6001\u66f4\u65b0\u3002</li> <li>\u91cf\u5b50\u4fe1\u9053\uff1a\u635f\u8017\u3001\u566a\u58f0\u3001\u9000\u76f8\u5e72\u5efa\u6a21\u3002</li> <li>\u5b89\u5168\u6307\u6807\uff1aQBER\u3001\u4e92\u4fe1\u606f\u3001\u53ef\u63d0\u53d6\u5bc6\u94a5\u7387\u3002</li> </ol>"},{"location":"qkd/foundation/qi/#_3","title":"\u5e38\u7528\u516c\u5f0f\uff08\u901f\u67e5\uff09","text":"<ul> <li>\u4e8c\u6001\u53e0\u52a0\uff1a\\(|\\psi\\rangle = \\alpha|0\\rangle + \\beta|1\\rangle, \\ |\\alpha|^2 + |\\beta|^2 = 1\\)</li> <li>\u51af\u8bfa\u4f9d\u66fc\u71b5\uff1a\\(S(\\rho) = -\\mathrm{Tr}(\\rho\\log_2\\rho)\\)</li> <li>\u4e8c\u5143\u71b5\u51fd\u6570\uff1a\\(h_2(e) = -e\\log_2 e - (1-e)\\log_2(1-e)\\)</li> </ul> <p>\u5728\u5e38\u89c1 BB84 \u6e10\u8fd1\u8fd1\u4f3c\u4e0b\uff0c\u53ef\u5199\u51fa\u793a\u610f\u6027\u5bc6\u94a5\u7387\u5173\u7cfb\uff1a</p> \\[ R \\approx q\\left[1 - 2h_2(e)\\right] \\] <p>\u5176\u4e2d \\(q\\) \u4e3a\u7b5b\u9009\u56e0\u5b50\uff0c\\(e\\) \u4e3a\u91cf\u5b50\u6bd4\u7279\u8bef\u7801\u7387\uff08QBER\uff09\u3002</p>"},{"location":"qkd/foundation/qi/#_4","title":"\u6298\u53e0\u5185\u5bb9\uff1a\u63a8\u5bfc\u4e0e\u4ee3\u7801","text":"\u5c55\u5f00\uff1a\u4ece\u4e92\u4fe1\u606f\u5230\u5bc6\u94a5\u7387\u8fd1\u4f3c\u7684\u63a8\u5bfc\u601d\u8def  \u8bbe Alice \u4e0e Bob \u7684\u8bef\u7801\u7387\u4e3a $e$\uff0c\u5728\u7406\u60f3\u7ea0\u9519\u6548\u7387\u8fd1\u4f3c\u4e0b\uff0c  $$ I(A:B) \\approx 1 - h_2(e) $$  \u5728\u5bf9\u79f0\u653b\u51fb\u4e0e\u6807\u51c6\u9690\u79c1\u653e\u5927\u8fd1\u4f3c\u4e0b\uff0c\u53ef\u7528  $$ \\chi(E:B) \\approx h_2(e) $$  \u5f97\u5230\u793a\u610f\u6027\u51c0\u5bc6\u94a5\u7387  $$ R \\approx q\\left[I(A:B) - \\chi(E:B)\\right] = q\\left[1 - 2h_2(e)\\right] $$  \u6ce8\u610f\uff1a\u8be5\u5f0f\u7528\u4e8e\u5165\u95e8\u76f4\u89c9\uff0c\u4e0d\u66ff\u4ee3\u4e25\u683c\u5b89\u5168\u8bc1\u660e\u4e0e\u6709\u9650\u7801\u957f\u5206\u6790\u3002   \u5c55\u5f00\uff1aQBER \u4e0e\u4e8c\u5143\u71b5\u7684 Python \u793a\u4f8b <pre><code>import math\n\n\ndef h2(e: float) -&gt; float:\n\tif e &lt;= 0.0 or e &gt;= 1.0:\n\t\treturn 0.0\n\treturn -e * math.log2(e) - (1 - e) * math.log2(1 - e)\n\n\ndef key_rate_bb84_asymptotic(e: float, q: float = 0.5) -&gt; float:\n\treturn q * (1 - 2 * h2(e))\n\n\nfor qber in [0.01, 0.03, 0.05, 0.08, 0.11]:\n\tprint(f\"QBER={qber:.2%}, R\u2248{key_rate_bb84_asymptotic(qber):.4f}\")\n</code></pre>"},{"location":"qkd/foundation/qi/#_5","title":"\u53cd\u9988","text":"<p>\u5982\u679c\u8fd9\u9875\u5185\u5bb9\u5bf9\u4f60\u6709\u5e2e\u52a9\uff0c\u6b22\u8fce\uff1a</p> <ul> <li>\u5728\u4ed3\u5e93\u70b9\u4e00\u4e2a Star \u652f\u6301\u6301\u7eed\u66f4\u65b0\u3002</li> <li>\u5728\u8bc4\u8bba\u533a\u6216 Issue \u7559\u8a00\u4f60\u5e0c\u671b\u8865\u5145\u7684\u4e3b\u9898\uff08\u5982\u6709\u9650\u7801\u957f\u3001\u5b89\u5168\u8bc1\u660e\u3001\u5668\u4ef6\u65e0\u5173 QKD\uff09\u3002</li> </ul>"},{"location":"qkd/foundation/qm/","title":"qm","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/protocol/bb84/","title":"bb84","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/protocol/decoy-state/","title":"decoy state","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"qkd/security/security-proof/","title":"security proof","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"tools/","title":"tools","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"tools/dev/","title":"dev","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"tools/research/","title":"research","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"tools/workflow/","title":"workflow","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"}]}