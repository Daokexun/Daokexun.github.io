5757\uff0c\u8fd9\u4e9b\u5728 Typora \u548c\u7f51\u7ad9\u91cc\u770b\u8d77\u6765\u662f\u4e00\u6a21\u4e00\u6837\u7684\u3002</li> <li>\u5f53\u4f60\u7528\u5230\u7f51\u7ad9\u4e13\u6709\u7684\u9ad8\u7ea7\u7279\u6548\uff08\u6bd4\u5982 <code>!!! note</code> \u63d0\u793a\u6846\u3001\u6392\u7248\u6807\u7b7e\u9875\u7b49\uff09\u65f6\uff0c\u4e0d\u8981\u7ba1 Typora \u91cc\u5b83\u957f\u5f97\u591a\u4e11\uff0c\u53ea\u8981\u4f60\u5728\u53f3\u8fb9\u7684\u7f51\u9875\u6d4f\u89c8\u5668\u91cc\u770b\u5230\u5b83\u662f\u6f02\u4eae\u7684\u5c31\u884c\u4e86\uff01</li> </ol> <p>\u53bb\u6539\u4e00\u4e0b <code>yml</code> \u5e76\u8c03\u6574\u4e00\u4e0b\u4ee3\u7801\u5757\u683c\u5f0f\uff0c\u770b\u770b\u7f51\u9875\u662f\u4e0d\u662f\u77ac\u95f4\u5b8c\u7f8e\u4e86\uff1f</p>"},{"location":"ai/","title":"ai","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/dl/cv/","title":"cv","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/dl/llm/","title":"llm","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/dl/nn-basics/","title":"nn basics","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/ml/supervised/","title":"supervised","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/ml/unsupervised/","title":"unsupervised","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/practice/papers/","title":"papers","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"ai/practice/reproduce/","title":"reproduce","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"class/","title":"class","text":"<p>\u4eca\u5929\u4e5f\u662f\u6bd4\u8f83\u95f2\uff0c\u60f3\u7740\u628a\u4e0a\u8fc7\u7684\u8bfe\u90fd\u603b\u7ed3\u4e00\u4e0b\u3002</p>"},{"location":"class/academic-plotting/","title":"\u4e13\u4e1a\u5b66\u672f\u5236\u56fe","text":"<p>\u8fd9\u91cc\u662f\u4e00\u6bb5\u8bfe\u7a0b\u7684\u603b\u4f53\u4ecb\u7ecd\uff1a</p> <p>\u8bfe\u7a0b\u4f53\u9a8c</p> <p>\u6388\u8bfe\u6559\u5e08 \u674e\u56db</p> <p>\u8bfe\u5802\u4f53\u9a8c \u6559\u6388 Origin\u3001Illustrator \u7b49\u8f6f\u4ef6\u5728\u5b66\u672f\u4e2d\u7684\u5e94\u7528\u3002</p> <p>\u8003\u6838\u5f62\u5f0f \u671f\u672b\u5927\u4f5c\u4e1a\uff08\u7ed8\u5236\u4e00\u4efd\u4f18\u8d28\u5b66\u672f\u56fe\u8868\uff09 100%</p> <p>\u5206\u6570\u6784\u6210 \u968f\u5802\u7ec3\u4e60 30%\uff1b\u671f\u672b 70%</p>"},{"location":"class/academic-plotting/#_2","title":"\u4e3a\u4ec0\u4e48\u9700\u8981\u5b66\u672f\u5236\u56fe","text":"<p>\u5728\u8fd9\u91cc\u53ef\u4ee5\u63d2\u5165\u56fe\u7247\u548c\u6587\u5b57\u7ed3\u5408\uff1a \u76f4\u89c2\u5730\u5c55\u793a\u6570\u636e\uff0c\u662f\u6bcf\u7bc7\u4f18\u79c0\u8bba\u6587\u7684\u5fc5\u5907\u8981\u6c42\u3002</p>"},{"location":"class/application-math-tools/","title":"\u9762\u5411\u5e94\u7528\u7684 Mathematica/MATLAB","text":"<p>\u8fd9\u95e8\u8bfe\u6574\u4f53\u504f\u786c\u6838\uff0c\u4f46\u5f88\u5b9e\u7528\u3002\u540d\u5b57\u91cc\u6709 Mathematica \u548c MATLAB\uff0c\u4e0d\u8fc7\u8001\u5e08\u5b9e\u9645\u4e3b\u8981\u8bb2\u7684\u662f Mathematica\uff08MMA\uff09\uff0cMATLAB \u90e8\u5206\u57fa\u672c\u4e0d\u6d89\u53ca\u3002</p> <p>\u8bfe\u7a0b\u901f\u89c8</p> <ul> <li>\u8bfe\u7a0b\u5f3a\u5ea6\uff1a\u4e2d\u7b49\u504f\u4e0a\uff08\u5bf9\u7406\u5de5\u79d1\u540c\u5b66\u66f4\u53cb\u597d\uff09</li> <li>\u4e3b\u8981\u5185\u5bb9\uff1aMathematica \u5b9e\u64cd\u4e0e\u4ee3\u7801\u8bb2\u89e3</li> <li>\u8003\u6838\u65b9\u5f0f\uff1a\u9879\u76ee + \u62a5\u544a</li> <li>\u9002\u5408\u4eba\u7fa4\uff1a\u7535\u4fe1\u3001\u8ba1\u7b97\u673a\u3001\u6750\u6599\u3001\u5316\u5b66\u7b49\u7406\u5de5\u79d1\u65b9\u5411</li> </ul>"},{"location":"class/application-math-tools/#_1","title":"\u8bfe\u5802\u4f53\u9a8c","text":"<p>\u8001\u5e08\u4e0a\u8bfe\u4f1a\u9010\u884c\u5206\u6790\u4ee3\u7801\uff0c\u5e76\u73b0\u573a\u6f14\u793a\u8fd0\u884c\u7ed3\u679c\uff0c\u5c5e\u4e8e\u201c\u8fb9\u8bb2\u8fb9\u8dd1\u201d\u7684\u5b9e\u6218\u578b\u6559\u5b66\u3002</p> <p> \u90b5\u8001\u5e08\u7684\u7a7f\u642d\u603b\u7ed9\u6211\u4e00\u79cd\u201c\u6536\u79df\u6536\u817b\u4e86\u6765\u8bb2\u4e24\u8282\u8bfe\u201d\u7684\u9519\u89c9\uff08bushi\uff09\u3002</p> <p>\u4ece\u5b9e\u7528\u6027\u770b\uff0c\u8fd9\u95e8\u8bfe\u503c\u5f97\u4e0a\u3002\u4e2d\u6587\u4e92\u8054\u7f51\u91cc\u7cfb\u7edf\u8bb2 Mathematica \u7684\u5185\u5bb9\u4e0d\u7b97\u591a\uff0c\u8bfe\u5802\u4e0a\u80fd\u5c11\u8d70\u4e0d\u5c11\u5f2f\u8def\u3002</p>"},{"location":"class/application-math-tools/#_2","title":"\u8bfe\u7a0b\u8282\u594f\u4e0e\u8981\u6c42","text":"<ul> <li>\u8001\u5e08\u4f1a\u968f\u673a\u70b9\u4eba\u56de\u7b54\u95ee\u9898\uff08\u6709\u4e00\u70b9\u201c\u770b\u773c\u7f18\u201d\uff09\u3002</li> <li>\u5927\u7ea6\u6709 6 \u6b21\u8bfe\u524d\u7b7e\u5230\uff0c\u901a\u5e38\u662f\u6392\u961f\u6253\u94a9\u3002</li> <li>\u4e1c\u6821\u540c\u5b66\u4f53\u611f\u8981\u6c42\u7565\u9ad8\u4e00\u4e9b\uff0c\u53ef\u80fd\u548c\u9009\u8bfe\u4eba\u7fa4\u4e2d\u7406\u5de5\u79d1\u6bd4\u4f8b\u66f4\u9ad8\u6709\u5173\u3002</li> </ul>"},{"location":"class/application-math-tools/#_3","title":"\u8bfe\u5802\u7167\u7247","text":""},{"location":"class/application-math-tools/#_4","title":"\u6210\u7ee9\u4e0e\u5efa\u8bae","text":"<p>\u6211\u6700\u540e\u7684\u6210\u7ee9\u662f B+\uff0885-89\uff09\uff0c\u73ed\u7ea7\u6392\u540d\u5927\u7ea6 56/109\uff0c\u5c5e\u4e8e\u4e2d\u4f4d\u6570\u9644\u8fd1\u3002</p> <p>\u5982\u679c\u53ea\u662f\u63d0\u5347\u6280\u80fd\u3001\u62d3\u5bbd\u5de5\u5177\u6808\uff0c\u8fd9\u95e8\u8bfe\u6027\u4ef7\u6bd4\u4e0d\u9519\uff1b\u5982\u679c\u4f60\u540e\u7eed\u6709\u7559\u5b66\u89c4\u5212\u4e14\u5f88\u5728\u610f\u6210\u7ee9\u8868\u73b0\uff0c\u5efa\u8bae\u7ed3\u5408\u81ea\u5df1\u7684\u65f6\u95f4\u7cbe\u529b\u8c28\u614e\u8bc4\u4f30\u6295\u5165\u3002</p>"},{"location":"class/history-of-tech/","title":"\u79d1\u6280\u7b80\u53f2","text":"<p>\u8fd9\u95e8\u8bfe\u9002\u5408\u4f5c\u4e3a\u7406\u5de5\u79d1\u8bfe\u7a0b\u4e4b\u5916\u7684\u89c6\u91ce\u8865\u5145\uff0c\u6838\u5fc3\u4e0d\u662f\u80cc\u5e74\u4ee3\uff0c\u800c\u662f\u7406\u89e3\u201c\u6280\u672f\u5982\u4f55\u5851\u9020\u793e\u4f1a\u3001\u793e\u4f1a\u53c8\u5982\u4f55\u53cd\u8fc7\u6765\u9009\u62e9\u6280\u672f\u201d\u3002</p> <p>\u8bfe\u7a0b\u901f\u89c8</p> <ul> <li>\u5b66\u4e60\u91cd\u70b9\uff1a\u6280\u672f\u6f14\u8fdb\u903b\u8f91\u4e0e\u5173\u952e\u8f6c\u6298\u70b9</li> <li>\u8bfe\u5802\u5f62\u5f0f\uff1a\u8bb2\u6388 + \u8ba8\u8bba</li> <li>\u9002\u5408\u4eba\u7fa4\uff1a\u5e0c\u671b\u8865\u9f50\u79d1\u6280\u53f2\u4e0e\u8de8\u5b66\u79d1\u89c6\u89d2\u7684\u540c\u5b66</li> </ul>"},{"location":"class/history-of-tech/#_2","title":"\u8bfe\u7a0b\u770b\u70b9","text":"<ul> <li>\u4ece\u7ecf\u5178\u6280\u672f\u8282\u70b9\u51fa\u53d1\uff0c\u68b3\u7406\u201c\u53d1\u660e-\u5e94\u7528-\u6269\u6563-\u5f71\u54cd\u201d\u7684\u5b8c\u6574\u94fe\u8def\u3002</li> <li>\u8ba8\u8bba\u6280\u672f\u53d1\u5c55\u80cc\u540e\u7684\u7ecf\u6d4e\u3001\u5236\u5ea6\u4e0e\u6587\u5316\u56e0\u7d20\uff0c\u800c\u4e0d\u53ea\u505c\u7559\u5728\u65f6\u95f4\u7ebf\u3002</li> <li>\u5bf9\u505a\u79d1\u7814\u3001\u5de5\u7a0b\u5b9e\u8df5\u548c\u5199\u4f5c\u90fd\u5f88\u6709\u5e2e\u52a9\uff0c\u80fd\u63d0\u5347\u95ee\u9898\u5206\u6790\u7684\u7eb5\u6df1\u611f\u3002</li> </ul>"},{"location":"class/history-of-tech/#_3","title":"\u5b66\u4e60\u5efa\u8bae","text":"<ul> <li>\u8bfe\u524d\u5feb\u901f\u4e86\u89e3\u5f53\u8282\u4e3b\u9898\u7684\u5386\u53f2\u80cc\u666f\uff0c\u4e0a\u8bfe\u4f1a\u66f4\u5bb9\u6613\u8ddf\u4e0a\u8ba8\u8bba\u3002</li> <li>\u5efa\u8bae\u7ed3\u5408\u81ea\u5df1\u7684\u4e13\u4e1a\u65b9\u5411\u505a\u5c0f\u578b\u5ef6\u4f38\u9605\u8bfb\uff0c\u6536\u83b7\u4f1a\u660e\u663e\u66f4\u5927\u3002</li> <li>\u8fd9\u95e8\u8bfe\u7684\u4ef7\u503c\u5728\u4e8e\u201c\u5efa\u7acb\u6846\u67b6\u201d\uff0c\u4e0d\u662f\u201c\u8bb0\u4f4f\u6240\u6709\u7ec6\u8282\u201d\u3002</li> </ul>"},{"location":"cs/","title":"cs","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"cs/programming/c-cpp/","title":"c cpp","text":"<p>\u9875\u9762\u5efa\u8bbe\u4e2d\u3002</p>"},{"location":"cs/programming/dsa/","title":"dsa","text":"<p>\u9875\u9762\u5efa\u8bbe\u